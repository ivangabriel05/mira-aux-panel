<Window x:Class="MiraAuxPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="🎯 MIRA AUXILIAR PANEL" Height="450" Width="400"
        Background="#121212" Foreground="White" WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinus">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row0>
            <TextBlock Text="MIRA AUX PANEL" FontSize="22" FontWeight="Bold" Foreground="#00FF7F" HorizontalAlignment="Center"/>
            <TextBlock Text="Otimização de Input &amp; Sensibilidade" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,20"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            
            <TextBlock Text="Multiplicador Eixo X (Horizontal)" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderX" Minimum="0.1" Maximum="3.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderX_ValueChanged"/>
                <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderX, Path=Value, StringFormat={}{0:F1}x}" Width="40" TextAlignment="Right" FontWeight="Bold" Foreground="#00FF7F"/>
            </Grid>

            <TextBlock Text="Multiplicador Eixo Y (Vertical)" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderY" Minimum="0.1" Maximum="3.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderY_ValueChanged"/>
                <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderY, Path=Value, StringFormat={}{0:F1}x}" Width="40" TextAlignment="Right" FontWeight="Bold" Foreground="#00FF7F"/>
            </Grid>

            <Border Background="#1A1A1A" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <TextBlock x:Name="TxtEngineStatus" Text="Motor de Sensibilidade: Inativo" Foreground="Orange" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="10">
            <Button x:Name="BtnToggleEngine" Content="ATIVAR MOTOR DE MIRA" Background="#00FF7F" Foreground="Black" FontWeight="Bold" Height="40" Click="BtnToggleEngine_Click" Cursor="Hand"/>
            <Button x:Name="BtnApplyTweaks" Content="Otimizar Registro (Input Lag)" Background="#1E1E1E" Foreground="White" BorderBrush="#333" Height="35" Click="BtnApplyTweaks_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>